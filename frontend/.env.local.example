# Copy this file to .env.local and set your deployed API Gateway URL.
# Get the value by running: aws cloudformation describe-stacks --stack-name agent-browser --query 'Stacks[0].Outputs[?OutputKey==`ApiUrl`].OutputValue' --output text
VITE_API_URL=https://YOUR_API_GATEWAY_ID.execute-api.us-east-1.amazonaws.com
